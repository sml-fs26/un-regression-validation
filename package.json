{
  "name": "un-regression-validation",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "lint": "npm run lint:eslint && npm run lint:stylelint && npm run lint:forbidden-libraries && npm run check",
    "lint:eslint": "eslint \"src/**/*.{ts,js,svelte}\" \"tests/**/*.ts\" \"tests-e2e/**/*.ts\" \"tools/**/*.js\" \".storybook/**/*.ts\" \"scripts/**/*.mjs\"",
    "lint:stylelint": "stylelint \"src/**/*.{css,svelte}\"",
    "lint:forbidden-libraries": "node tools/forbidden-libraries-check.js",
    "generate:fixtures": "node scripts/gen-heartbeat-fixture.mjs",
    "storybook": "storybook dev -p 6006 --no-open",
    "build-storybook": "storybook build -o storybook-static --quiet",
    "test": "npm run build && vitest run",
    "test:unit": "vitest run",
    "test:e2e": "npm run build-storybook && playwright test",
    "test:e2e:update": "npm run build-storybook && playwright test --update-snapshots"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@storybook/addon-essentials": "^8.6.18",
    "@storybook/addon-interactions": "^8.6.18",
    "@storybook/blocks": "^8.6.18",
    "@storybook/svelte": "^8.6.18",
    "@storybook/sveltekit": "^8.6.18",
    "@sveltejs/adapter-static": "^3.0.6",
    "@sveltejs/kit": "^2.5.27",
    "@sveltejs/vite-plugin-svelte": "^3.1.2",
    "@types/node": "^20.14.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.0",
    "eslint-plugin-svelte": "^2.43.0",
    "eslint-plugin-un-regression": "file:./tools/eslint",
    "node-html-parser": "^6.1.13",
    "postcss": "^8.4.47",
    "postcss-html": "^1.7.0",
    "storybook": "^8.6.18",
    "stylelint": "^16.9.0",
    "svelte": "^4.2.19",
    "svelte-check": "^3.8.6",
    "svelte-eslint-parser": "^0.41.1",
    "typescript": "^5.5.4",
    "vite": "^5.4.8",
    "vitest": "^1.6.0"
  }
}
